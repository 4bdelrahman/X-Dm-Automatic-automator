# Copy this to .env and fill in all values

# X (Twitter) Credentials
X_USERNAME=your_twitter_username
X_PASSWORD=your_twitter_password
X_EMAIL=your_email@example.com   # Used if X asks for phone/email verification

# Google Sheets
GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}   # Single-line JSON string

# DM Settings
DM_TEMPLATE=Hey {{name}}, I came across your profile and wanted to reach out!
MAX_DMS_PER_RUN=20
DELAY_MIN_MS=45000     # 45 seconds minimum between DMs
DELAY_MAX_MS=90000     # 90 seconds maximum between DMs
STATUS_COLUMN=Z        # Which column to write DM status in the Google Sheet

# Redis (auto-provided by Railway Redis plugin — only set manually for local dev)
REDIS_URL=redis://localhost:6379

# Security
API_SECRET=generate_a_random_32_char_string_here

# Frontend URL (set after Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# Server
PORT=3001
NODE_ENV=development
